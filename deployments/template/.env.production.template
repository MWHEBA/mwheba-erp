# ============================================================
# Django Core Settings - إعدادات Django الأساسية
# ============================================================
# ✅ SECURE: Strong SECRET_KEY generated for production
SECRET_KEY=CHANGE_THIS_TO_UNIQUE_SECRET_KEY

# ⚠️ CRITICAL: Must be False in production!
DEBUG=False

# Allowed Hosts - الدومينات المسموحة
ALLOWED_HOSTS=client.domain.com,www.client.domain.com

# Site URL for QR Code generation and external links
SITE_URL=https://client.domain.com

# ============================================================
# Database Configuration - إعدادات قاعدة البيانات
# ============================================================
DB_ENGINE=mysql
DB_NAME=database_name
DB_USER=database_user
DB_PASSWORD=CHANGE_THIS_DATABASE_PASSWORD
DB_HOST=localhost
DB_PORT=3306
DB_CONN_MAX_AGE=0

# ============================================================
# Static & Media Files
# ============================================================
STATIC_URL=/static/
STATIC_ROOT=staticfiles
MEDIA_URL=/media/
MEDIA_ROOT=media

# ============================================================
# Cache Configuration
# ============================================================
REDIS_URL=
REDIS_ENABLED=False

# ============================================================
# Celery Configuration
# ============================================================
CELERY_BROKER_URL=
CELERY_RESULT_BACKEND=
CELERY_TASK_ALWAYS_EAGER=True

# ============================================================
# Email Configuration
# ============================================================
EMAIL_BACKEND=utils.email_backend.SSLEmailBackend
EMAIL_HOST=mail.client.com
EMAIL_PORT=587
EMAIL_USE_SSL=False
EMAIL_USE_TLS=True
EMAIL_HOST_USER=info@client.com
EMAIL_HOST_PASSWORD=CHANGE_THIS_EMAIL_PASSWORD
DEFAULT_FROM_EMAIL=info@client.com
SERVER_EMAIL=info@client.com
EMAIL_TIMEOUT=30

# ============================================================
# Security Settings
# ============================================================
SECURE_SSL_REDIRECT=True
SESSION_COOKIE_SECURE=True
CSRF_COOKIE_SECURE=True
SECURE_HSTS_SECONDS=31536000
SECURE_HSTS_INCLUDE_SUBDOMAINS=True
SECURE_HSTS_PRELOAD=True
SESSION_COOKIE_HTTPONLY=True
SESSION_COOKIE_SAMESITE=Strict
CSRF_COOKIE_HTTPONLY=True
SESSION_COOKIE_AGE=1800

# ============================================================
# SSH Deployment Configuration
# ============================================================
SSH_HOST=server_ip
SSH_PORT=22
SSH_USER=username
SSH_PASSWORD=CHANGE_THIS_SSH_PASSWORD
SSH_KEY_PATH=
SSH_KEY_PASSPHRASE=
SSH_REMOTE_PATH=/path/to/deployment

# ============================================================
# Bridge Agent Configuration
# ============================================================
BRIDGE_AGENTS=ZKTeco:CHANGE_THIS_BRIDGE_SECRET

# ============================================================
# Monitoring & Logging
# ============================================================
LOG_LEVEL=WARNING
MONITORING_ENABLED=True
ALERT_EMAIL_ENABLED=True
DEFAULT_ALERT_EMAIL=admin@client.com
